{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Ева-стиль",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "core:window:allow-show",
    "core:window:allow-set-title",
    "core:event:default",
    "dialog:default",
    "opener:default",
    "allow-eva-commands"
  ]
}
